print()

check("<script/> 태그 있어도 파싱 성공", len(p) > 0)
check("총계 행 제외됨 (1건만 남음)", len(p) == 1)
check("2016.01 → 2016-01 변환", "2016-01" in p)
check("총계 이중계상 없음 (expDlr 154, 308 아님)", p["2016-01"]["value"] == 154.0)
check("중량 정상", p["2016-01"]["weight"] == 20.0)

# 오류코드 해설
print()
print("resultCode 00 해설:", sources._diagnose_response(REAL))

